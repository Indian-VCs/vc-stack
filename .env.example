# Local dev environment for the admin portal.
# Copy to `.env.local` (which is gitignored) and fill in real values.
#
# In production, set these as Cloudflare Worker secrets — never put real
# credentials in this file or any tracked .env.
#
#   wrangler secret put SESSION_PASSWORD
#   wrangler secret put ADMIN_EMAIL
#   wrangler secret put ADMIN_PASSWORD_HASH

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# 32+ character random string used to sign and encrypt session cookies.
# Generate with: openssl rand -base64 48
SESSION_PASSWORD=

# Admin email (lower-cased on lookup).
ADMIN_EMAIL=

# bcrypt hash of the admin password. Generate with:
#   npx tsx scripts/hash-password.ts 'your-very-strong-password-here'
# IMPORTANT: bcrypt hashes start with `$2b$12$...`. Next.js's env loader
# interpolates `$VAR` syntax even inside single-quoted values, silently
# mangling the hash. ALWAYS escape every `$` with `\$` in this file:
#   ADMIN_PASSWORD_HASH=\$2b\$12\$AW5Mu3YfPXt.XDrepfu...
# `wrangler secret put` does not have this problem — paste unescaped there.
ADMIN_PASSWORD_HASH=

# ── OPTIONAL ──────────────────────────────────────────────────────────────────

# Local SQLite path. Defaults to ./local.db.
# DB_PATH=./local.db
